{
  "name": "geodrop",
  "scripts": {
    "anchor-build": "cd anchor && anchor build",
    "anchor-test": "cd anchor && anchor test --skip-deploy",
    "build": "next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "codama:js": "codama run js",
    "dev": "next dev",
    "eas-build-pre-install": "corepack enable && pnpm install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "setup": "npm run anchor-build && npm run codama:js",
    "start": "next start"
  },
  "description": "Next.js, Tailwind, @solana/kit, Anchor vault program",
  "keywords": [
    "anchor",
    "kit",
    "nextjs",
    "react",
    "solana-kit",
    "tailwind",
    "typescript"
  ],
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@geodrop/client": "workspace:*",
    "@lifi/sdk": "^3.16.3",
    "@lifi/widget": "^3.40.12",
    "@mysten/sui": "^2.16.2",
    "@solana-mobile/wallet-standard-mobile": "^0.5.3",
    "@solana/kit": "^6.3.0",
    "@solana/kit-client-rpc": "^0.7.0",
    "@solana/kit-plugin-rpc": "^0.7.0",
    "@solana/wallet-standard-features": "^1.3.0",
    "@tanstack/react-query": "^5.100.9",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "leaflet": "^1.9.4",
    "leaflet-geosearch": "^4.4.0",
    "lucide-react": "^1.14.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "sonner": "^2.0.7",
    "swr": "^2.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.3.8",
    "@codama/renderers-js": "^1.5.5",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "codama": "^1.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
